datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  firstName      String
  lastName       String
  phone          String
  role           String
  country        String
  profilePic     String?
  additionalInfo String?
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())

  // Relations
  approvals Approval[]
}

model Vendor {
  id          String   @id @default(uuid())
  companyName String
  gstNumber   String
  email       String   @unique
  phone       String
  category    String
  status      String   @default("Active")
  createdAt   DateTime @default(now())

  // Relations
  quotations     Quotation[]
  purchaseOrders PurchaseOrder[]
  rfqs           RFQ[]
}

model RFQ {
  id          String   @id @default(uuid())
  title       String
  category    String   @default("General")
  description String   @db.Text
  deadline    DateTime
  status      String   @default("Open")
  attachments String?  @db.Text
  createdAt   DateTime @default(now())

  // Relations
  quotations Quotation[]
  lineItems  RFQLineItem[]
  vendors    Vendor[]
}

model RFQLineItem {
  id       String @id @default(uuid())
  item     String
  qty      Int
  unit     String
  rfqId    String

  // Relations
  rfq      RFQ    @relation(fields: [rfqId], references: [id], onDelete: Cascade)
}

model Quotation {
  id          String   @id @default(uuid())
  price       Decimal
  deliveryETA String
  remarks     String?
  status      String   @default("Pending")
  createdAt   DateTime @default(now())

  // Foreign Keys
  rfqId    String
  vendorId String

  // Relations
  rfq            RFQ             @relation(fields: [rfqId], references: [id])
  vendor         Vendor          @relation(fields: [vendorId], references: [id])
  purchaseOrders PurchaseOrder[]
}

model Approval {
  id         String   @id @default(uuid())
  entityId   String   // Can point to RFQ, Quotation, etc.
  entityType String
  status     String
  remarks    String?
  createdAt  DateTime @default(now())

  // Foreign Keys
  approverId String

  // Relations
  approver User @relation(fields: [approverId], references: [id])
}

model PurchaseOrder {
  poNumber    String   @id
  totalAmount Decimal
  status      String   @default("Pending")
  createdAt   DateTime @default(now())

  // Foreign Keys
  quotationId String
  vendorId    String

  // Relations
  quotation Quotation @relation(fields: [quotationId], references: [id])
  vendor    Vendor    @relation(fields: [vendorId], references: [id])
  invoices  Invoice[]
}

model Invoice {
  invoiceNumber String   @id
  taxAmount     Decimal
  totalAmount   Decimal
  paymentStatus String   @default("Unpaid")
  createdAt     DateTime @default(now())

  // Foreign Keys
  poNumber String

  // Relations
  purchaseOrder PurchaseOrder @relation(fields: [poNumber], references: [poNumber])
}

model VerificationToken {
  id      String   @id @default(uuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id      String   @id @default(uuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}